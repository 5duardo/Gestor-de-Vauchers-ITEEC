{
  "name": "gestor-de-vauchers-iteec",
  "version": "1.0.3",
  "description": "Generador de vouchers de pago para docentes ITEEC",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder -w",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "build": {
    "appId": "com.iteec.vouchers",
    "productName": "Gestor de Vauchers ITEEC",
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "assets/logo-pantera.png"
    },
    "nsis": {
      "artifactName": "Generador-Vouchers-ITEEC-Setup.exe",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "portable": {
      "artifactName": "Generador-Vouchers-ITEEC.exe"
    },
    "publish": {
      "provider": "github",
      "owner": "5duardo",
      "repo": "Gestor-de-Vauchers-ITEEC"
    },
    "directories": {
      "output": "dist"
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "electron-updater": "^6.3.0",
    "handlebars": "^4.7.9",
    "puppeteer": "^24.42.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "electron": "^41.3.0",
    "electron-builder": "^24.13.3"
  }
}
